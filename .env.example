APP_NAME=Visadorm
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://p2p.visadorm.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=visadorm_p2p
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@visadorm.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_WALLETCONNECT_PROJECT_ID=

# Exchange Rate API (https://www.exchangerate-api.com)
EXCHANGERATE_API_KEY=

# Blockchain — Private Keys (NEVER commit real values)
OPERATOR_PRIVATE_KEY=
ADMIN_PRIVATE_KEY=
ALCHEMY_API_KEY=

# Blockchain — Deployed Contracts (Base Sepolia)
TRADE_ESCROW_ADDRESS=0xD9771DF5f6EA84AceeA98F6DF27497c159dd940c
SOULBOUND_NFT_ADDRESS=0xD81a5b95550E94C7ec995af6BaaD4ab7281B5FFD
USDC_ADDRESS=0xe3B1038eecea95053256D0e5d52D11A0703D1c4F
FEE_WALLET_ADDRESS=0xb0858aa1264d5d5433dac742b2c30abfc7798736
ADMIN_MULTISIG_ADDRESS=0x91511adcbbe32bc5202b73741bcd7adfbf9ab00e

# Admin Seeder
ADMIN_PASSWORD=
ADMIN_WALLET_ADDRESS=

# Cloudflare Cache Purge
CLOUDFLARE_API_TOKEN=

# Twilio (SMS) — optional
TWILIO_SID=
TWILIO_TOKEN=
