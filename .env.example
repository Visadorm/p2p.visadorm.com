APP_NAME=Visadorm
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://p2p.visadorm.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=visadorm_p2p
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@visadorm.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_WALLETCONNECT_PROJECT_ID=

# Exchange Rate API (https://www.exchangerate-api.com)
EXCHANGERATE_API_KEY=

# Blockchain — Private Keys (NEVER commit real values)
OPERATOR_PRIVATE_KEY=
ADMIN_PRIVATE_KEY=
ALCHEMY_API_KEY=

# Blockchain — Deployed Contracts (Base Sepolia)
TRADE_ESCROW_ADDRESS=0x24320787EA129E52aDD81B3e72d1AD21D2923a45
SOULBOUND_NFT_ADDRESS=0xA31aaDAef8ED85ea73b4665291b3c4E7ED5F6bb6
USDC_ADDRESS=0xb7cDCbeA16D9A3ae36f8307512b29115B8137ffB
FEE_WALLET_ADDRESS=0xb0858aa1264d5d5433dac742b2c30abfc7798736
ADMIN_MULTISIG_ADDRESS=0x91511adcbbe32bc5202b73741bcd7adfbf9ab00e

# Admin Seeder
ADMIN_PASSWORD=
ADMIN_WALLET_ADDRESS=

# Cloudflare Cache Purge
CLOUDFLARE_API_TOKEN=

# Twilio (SMS) — optional
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
