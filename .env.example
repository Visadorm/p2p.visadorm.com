APP_NAME=Visadorm
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://p2p.visadorm.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=visadorm_p2p
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Reverb (WebSocket for real-time trade updates)
REVERB_APP_ID=visadorm-p2p
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=p2p.visadorm.com
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@visadorm.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_WALLETCONNECT_PROJECT_ID=

# Exchange Rate API (https://www.exchangerate-api.com)
EXCHANGERATE_API_KEY=

# Blockchain — Private Keys (NEVER commit real values)
OPERATOR_PRIVATE_KEY=
ADMIN_PRIVATE_KEY=
ALCHEMY_API_KEY=

# Blockchain — Deployed Contracts
# Testnet (Base Sepolia): update these after deploying contracts
TRADE_ESCROW_ADDRESS=
SOULBOUND_NFT_ADDRESS=
USDC_ADDRESS=
FEE_WALLET_ADDRESS=
ADMIN_MULTISIG_ADDRESS=

# Admin Seeder
ADMIN_PASSWORD=
ADMIN_WALLET_ADDRESS=

# Twilio (SMS) — optional
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
